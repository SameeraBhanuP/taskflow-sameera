# Copy this file to .env and fill in values before running docker compose up
# Never commit the actual .env file to git

# PostgreSQL
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_secret

# JWT — use a long random secret in production
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret-before-deploying

# App environment
ENVIRONMENT=development
